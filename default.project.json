{
  "globIgnorePaths": [
    "**/package.json",
    "**/tsconfig.json"
  ],
  "name": "roblox-ts-game",
  "tree": {
    "$className": "DataModel",
    "HttpService": {
      "$className": "HttpService"
    },
    "ReplicatedFirst": {
      "$className": "ReplicatedFirst",
      "TS": {
        "$className": "Folder",
        "app": {
          "$path": "out/app/replicatedfirst"
        }
      }
    },
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "TS": {
        "$className": "Folder",
        "components": {
          "$className": "Folder",
          "Button": {
            "$path": "out/components/Button"
          },
          "Header": {
            "$path": "out/components/Header"
          }
        },
        "config": {
          "$className": "Folder",
          "fonts": {
            "$path": "out/config/fonts.luau"
          }
        },
        "features": {
          "$className": "Folder",
          "inventory": {
            "$path": "out/features/inventory/shared"
          }
        },
        "hooks": {
          "$path": "out/hooks"
        },
        "providers": {
          "$className": "Folder",
          "root-provider": {
            "$path": "out/providers/root-provider.luau"
          }
        },
        "store": {
          "$path": "out/store"
        }
      },
      "rbxts_include": {
        "$path": "include",
        "node_modules": {
          "$className": "Folder",
          "@rbxts": {
            "$path": "node_modules/@rbxts"
          }
        }
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "TS": {
        "$className": "Folder",
        "features": {
          "$className": "Folder",
          "inventory": {
            "$path": "out/features/inventory/server"
          }
        }
      }
    },
    "SoundService": {
      "$className": "SoundService",
      "$properties": {
        "RespectFilteringEnabled": true
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "TS": {
          "$className": "Folder",
          "app": {
            "$path": "out/app/client"
          },
          "features": {
            "$className": "Folder",
            "inventory": {
              "$path": "out/features/inventory/client"
            }
          }
        }
      }
    },
    "Workspace": {
      "$className": "Workspace"
    }
  }
}