{
  "name": "roblox-ts-game",
  "globIgnorePaths": [
    "**/package.json",
    "**/tsconfig.json"
  ],
  "tree": {
    "$className": "DataModel",
    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "FilteringEnabled": true
      }
    },
    "HttpService": {
      "$className": "HttpService",
      "$properties": {
        "HttpEnabled": true
      }
    },
    "SoundService": {
      "$className": "SoundService",
      "$properties": {
        "RespectFilteringEnabled": true
      }
    },
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$ignoreUnknownInstances": true,
      "rbxts_include": {
        "$path": "include",
        "node_modules": {
          "$className": "Folder",
          "@rbxts": {
            "$path": "node_modules/@rbxts"
          }
        }
      },
      "TS": {
        "$className": "Folder",
        "components": {
          "$className": "Folder",
          "$ignoreUnknownInstances": true,
          "Button": {
            "$path": "out/components/Button"
          },
          "Header": {
            "$path": "out/components/Header"
          }
        },
        "config": {
          "$className": "Folder",
          "$ignoreUnknownInstances": true,
          "fonts": {
            "$path": "out/config/fonts.luau"
          }
        },
        "features": {
          "$className": "Folder",
          "$ignoreUnknownInstances": true,
          "inventory": {
            "$path": "out/features/inventory/shared"
          }
        },
        "hooks": {
          "$path": "out/hooks"
        },
        "providers": {
          "$className": "Folder",
          "$ignoreUnknownInstances": true,
          "root-provider": {
            "$path": "out/providers/root-provider.luau"
          }
        },
        "store": {
          "$path": "out/store"
        }
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$ignoreUnknownInstances": true,
      "TS": {
        "$className": "Folder",
        "app": {
          "$path": "out/app/server"
        },
        "features": {
          "$className": "Folder",
          "$ignoreUnknownInstances": true,
          "inventory": {
            "$path": "out/features/inventory/server"
          }
        }
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "$ignoreUnknownInstances": true,
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$ignoreUnknownInstances": true,
        "TS": {
          "$className": "Folder",
          "app": {
            "$path": "out/app/client"
          },
          "features": {
            "$className": "Folder",
            "$ignoreUnknownInstances": true,
            "inventory": {
              "$path": "out/features/inventory/client"
            }
          }
        }
      }
    },
    "ReplicatedFirst": {
      "$className": "ReplicatedFirst",
      "$ignoreUnknownInstances": true,
      "TS": {
        "$className": "Folder",
        "app": {
          "$path": "out/app/replicatedfirst"
        }
      }
    }
  }
}